LLM_API_KEY=sk-your-api-key-here          # or use OPENAI_API_KEY (backwards compatible)

# --- Basic Auth (Jira Cloud) ---
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your-jira-api-token-here

# --- PAT Auth (Jira Data Center / Server) ---
# Set auth_method: pat in config.yaml, then provide your token here:
# JIRA_PAT=your-personal-access-token-here
